# server/.env.example
#
# Copy to .env.local and fill in real values for local dev.
# For production: use `phantom sync --platform railway` to push secrets to
# Railway without the agent or shell history ever touching the values.
# See .phantom.toml at the repo root for the canonical sync target.
#
# Values beginning with `phm_` are Phantom vault reference stubs.
# Replace them with real values in .env.local, or run:
#   phantom init --env-file .env.local
# to seal an existing .env.local into the vault.

# --- Database (postgres-js) ---
# Local dev: docker compose up -d postgres → host port 55432
DATABASE_URL=postgres://pulse:pulse@localhost:55432/pulse

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=phm_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=phm_supabase_service_role_key

# --- GitHub OAuth (data-sync, not login auth) ---
GITHUB_CLIENT_ID=phm_github_client_id
GITHUB_CLIENT_SECRET=phm_github_client_secret

# --- Stripe ---
STRIPE_SECRET_KEY=phm_stripe_secret_key
STRIPE_WEBHOOK_SECRET=phm_stripe_webhook_secret
STRIPE_PRICE_ID_PRO=phm_stripe_price_id_pro

# --- SendGrid ---
SENDGRID_API_KEY=phm_sendgrid_api_key
SENDGRID_FROM_EMAIL=digest@pulse.ashlr.ai

# --- Pulse internals ---
# PULSE_CRON_SECRET: shared secret for Railway cron → /api/cron/* routes
PULSE_CRON_SECRET=phm_pulse_cron_secret
# PULSE_TOKEN_ENC_KEY: 32-byte hex key; pgcrypto encrypts GitHub OAuth tokens at rest
PULSE_TOKEN_ENC_KEY=phm_pulse_token_enc_key

# --- App URL (email links, OAuth redirects) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
